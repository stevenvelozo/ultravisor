{
	"ProviderIdentifier": "Pict-Router",

	"AutoInitialize": true,
	"AutoInitializeOrdinal": 0,

	"Routes":
	[
		{
			"path": "/Home",
			"template": "{~LV:Pict.PictApplication.showView(`Ultravisor-Dashboard`)~}"
		},
		{
			"path": "/Operations",
			"template": "{~LV:Pict.PictApplication.showView(`Ultravisor-OperationList`)~}"
		},
		{
			"path": "/OperationEdit",
			"template": "{~LV:Pict.PictApplication.showView(`Ultravisor-OperationEdit`)~}"
		},
		{
			"path": "/Schedule",
			"template": "{~LV:Pict.PictApplication.showView(`Ultravisor-Schedule`)~}"
		},
		{
			"path": "/Manifests/detail/:runHash",
			"template": "{~LV:Pict.PictApplication.showManifestDetail(Record.data.runHash)~}"
		},
		{
			"path": "/Manifests/:filter",
			"template": "{~LV:Pict.PictApplication.showManifestsFiltered(Record.data.filter)~}"
		},
		{
			"path": "/Manifests",
			"template": "{~LV:Pict.PictApplication.showView(`Ultravisor-ManifestList`)~}"
		},
		{
			"path": "/PendingInput",
			"template": "{~LV:Pict.PictApplication.showManifestsFiltered(`waiting`)~}"
		},
		{
			"path": "/Beacons",
			"template": "{~LV:Pict.PictApplication.showView(`Ultravisor-BeaconList`)~}"
		},
		{
			"path": "/Fleet",
			"template": "{~LV:Pict.PictApplication.showView(`Ultravisor-Fleet`)~}"
		},
		{
			"path": "/Timing",
			"template": "{~LV:Pict.PictApplication.showView(`Ultravisor-TimingView`)~}"
		},
		{
			"path": "/FlowEditor/:hash",
			"template": "{~LV:Pict.PictApplication.editOperationFromRoute(Record.data.hash)~}"
		},
		{
			"path": "/FlowEditor",
			"template": "{~LV:Pict.PictApplication.showView(`Ultravisor-FlowEditor`)~}"
		},
		{
			"path": "/Docs",
			"template": "{~LV:Pict.PictApplication.showView(`Ultravisor-Documentation`)~}"
		}
	]
}

{
	"name": "ultravisor-webinterface",
	"version": "0.0.1",
	"description": "Ultravisor Task Server Web Interface",
	"main": "source/Pict-Application-Ultravisor.js",
	"scripts": {
		"start": "node source/Pict-Application-Ultravisor.js",
		"prebuild": "node ./node_modules/pict-section-flow/scripts/generate-card-help.js ./docs/card-help ./source/card-help-content.js",
		"build": "npx quack build && node build/build-codemirror-bundle.js && npx quack copy"
	},
	"author": "steven velozo <steven@velozo.com>",
	"license": "MIT",
	"dependencies": {
		"pict": "^1.0.359",
		"pict-application": "^1.0.33",
		"pict-docuserve": "^0.0.32",
		"pict-provider": "^1.0.12",
		"pict-router": "^1.0.9",
		"pict-section-content": "^0.0.11",
		"pict-section-flow": "^0.0.17",
		"pict-section-form": "^1.0.195",
		"pict-section-markdowneditor": "^1.0.7",
		"pict-section-modal": "^0.0.1",
		"pict-section-objecteditor": "^1.0.1",
		"pict-view": "^1.0.67"
	},
	"devDependencies": {
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.40.0",
		"codemirror": "^6.0.2",
		"esbuild": "^0.27.4",
		"quackage": "^1.0.65"
	},
	"copyFilesSettings": {
		"whenFileExists": "overwrite"
	},
	"copyFiles": [
		{
			"from": "./ultravisor-webinterface*",
			"to": "./dist/"
		},
		{
			"from": "./html/*",
			"to": "./dist/"
		},
		{
			"from": "./css/**",
			"to": "./dist/css/"
		},
		{
			"from": "./node_modules/pict/dist/*",
			"to": "./dist/js/"
		},
		{
			"from": "../docs/**",
			"to": "./dist/docs/"
		}
	]
}

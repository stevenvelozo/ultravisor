					{ "Hash": "ec-fmt-so-Result", "Direction": "output", "Side": "right-top", "Label": "Result" }
				],
				"Data": { "Template": "Expression: {~D:Record.Operation.Expression~}\nResult: {~D:Record.Operation.Result~}\n", "Destination": "Operation.Output" }
			},
			{
				"Hash": "ec-write",
				"Type": "write-file",
				"X": 1160,
				"Y": 180,
				"Width": 200,
				"Height": 120,

					{ "Hash": "ec-wr-so-BytesWritten", "Direction": "output", "Side": "right-top", "Label": "BytesWritten" }
				],
				"Data": { "FilePath": "calc-result.txt", "Content": "{~D:Record.Operation.Output~}", "Encoding": "utf8" }
			},
			{

					{ "Hash": "ec-slv-so-Result", "Direction": "output", "Side": "right-top", "Label": "Result" }
				],
				"Data": { "Expression": "{~D:Record.Operation.Expression~}", "Destination": "Operation.Result" }
			},
			{
				"Hash": "ec-format",
				"Type": "template-string",
				"X": 870,
				"Y": 180,
				"Width": 220,
				"Height": 100,

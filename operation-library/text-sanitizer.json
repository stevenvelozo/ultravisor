			{ "Hash": "ts-sc2", "SourceNodeHash": "ts-read", "SourcePortHash": "ts-rd-so-FileContent", "TargetNodeHash": "ts-strip-tabs", "TargetPortHash": "ts-r1-si-InputString", "Data": {} },

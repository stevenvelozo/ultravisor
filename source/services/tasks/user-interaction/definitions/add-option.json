		{ "Name": "Label", "DataType": "String", "Required": true, "Description": "Display label for the option" },
		{ "Name": "Value", "DataType": "String", "Required": true, "Description": "Option value" },
		{ "Name": "ListAddress", "DataType": "String", "Required": true, "Description": "State address for the accumulated options list" }
	],
	"StateOutputs": [
		{ "Name": "Options", "DataType": "Object", "Description": "The accumulated options list" }

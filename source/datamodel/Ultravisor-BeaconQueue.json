{
	"_comment": "Ultravisor Beacon Queue — meadow DAL schema. Each table has a Stricture-style Columns block (legacy / documentation) plus a MeadowSchema block that drives the runtime DAL through meadow-connection-sqlite. Schema bootstrap and forward-only migration are handled by Service Ultravisor-Beacon-QueueStore via meadow-migrationmanager (introspect → diff → ALTER). Single-column lookup indices are declared with Indexed: true; the connector emits IX_M_T_{Table}_C_{Column} during createAllIndices.",
	"Tables":
	{
		"BeaconRun":
		{
			"TableName": "BeaconRun",
			"Domain": "Default",
			"Description": "Hub-owned run lifecycle record. One row per submitter-visible run; work items link back via RunID.",
			"Columns":
			[
				{ "Column": "IDBeaconRun", "DataType": "ID" },
				{ "Column": "GUIDBeaconRun", "DataType": "GUID", "Size": "36" },
				{ "Column": "CreateDate", "DataType": "DateTime" },
				{ "Column": "CreatingIDUser", "DataType": "Numeric", "Size": "int" },
				{ "Column": "UpdateDate", "DataType": "DateTime" },
				{ "Column": "UpdatingIDUser", "DataType": "Numeric", "Size": "int" },
				{ "Column": "Deleted", "DataType": "Boolean" },
				{ "Column": "DeleteDate", "DataType": "DateTime" },
				{ "Column": "DeletingIDUser", "DataType": "Numeric", "Size": "int" },
				{ "Column": "RunID", "DataType": "String", "Size": "128" },
				{ "Column": "IdempotencyKey", "DataType": "String", "Size": "256" },
				{ "Column": "SubmitterTag", "DataType": "String", "Size": "256" },
				{ "Column": "State", "DataType": "String", "Size": "32" },
				{ "Column": "StartedAt", "DataType": "DateTime" },
				{ "Column": "EndedAt", "DataType": "DateTime" },
				{ "Column": "CanceledAt", "DataType": "DateTime" },
				{ "Column": "CancelReason", "DataType": "String", "Size": "512" },
				{ "Column": "Metadata", "DataType": "String", "Size": "8192" }
			],
			"MeadowSchema":
			{
				"Scope": "BeaconRun",
				"DefaultIdentifier": "IDBeaconRun",
				"Domain": "Default",
				"Schema":
				[
					{ "Column": "IDBeaconRun",     "Type": "AutoIdentity", "Size": "Default" },
					{ "Column": "GUIDBeaconRun",   "Type": "String",       "Size": "36" },
					{ "Column": "CreateDate",      "Type": "CreateDate",   "Size": "Default" },
					{ "Column": "CreatingIDUser",  "Type": "Integer",      "Size": "int" },
					{ "Column": "UpdateDate",      "Type": "UpdateDate",   "Size": "Default" },
					{ "Column": "UpdatingIDUser",  "Type": "Integer",      "Size": "int" },
					{ "Column": "Deleted",         "Type": "Boolean",      "Size": "Default" },
					{ "Column": "DeleteDate",      "Type": "DateTime",     "Size": "Default" },
					{ "Column": "DeletingIDUser",  "Type": "Integer",      "Size": "int" },
					{ "Column": "RunID",           "Type": "String",       "Size": "128", "Indexed": true },
					{ "Column": "IdempotencyKey",  "Type": "String",       "Size": "256", "Indexed": true },
					{ "Column": "SubmitterTag",    "Type": "String",       "Size": "256" },
					{ "Column": "State",           "Type": "String",       "Size": "32" },
					{ "Column": "StartedAt",       "Type": "DateTime",     "Size": "Default" },
					{ "Column": "EndedAt",         "Type": "DateTime",     "Size": "Default" },
					{ "Column": "CanceledAt",      "Type": "DateTime",     "Size": "Default" },
					{ "Column": "CancelReason",    "Type": "String",       "Size": "512" },
					{ "Column": "Metadata",        "Type": "Text",         "Size": "Default" }
				],
				"DefaultObject":
				{
					"IDBeaconRun": 0, "GUIDBeaconRun": "",
					"CreateDate": null, "CreatingIDUser": 0,
					"UpdateDate": null, "UpdatingIDUser": 0,
					"Deleted": 0, "DeleteDate": null, "DeletingIDUser": 0,
					"RunID": "", "IdempotencyKey": "", "SubmitterTag": "",
					"State": "Active",
					"StartedAt": null, "EndedAt": null, "CanceledAt": null,
					"CancelReason": "", "Metadata": ""
				}
			}
		},

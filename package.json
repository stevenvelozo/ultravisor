{
    "name": "ultravisor",
    "version": "1.0.23",
    "description": "Cyclic process execution with ai integration.",
    "main": "source/Ultravisor.cjs",
    "bin": {
        "ultravisor": "./source/cli/Ultravisor-Run.cjs"
    },
    "scripts": {
        "start": "node source/cli/Ultravisor-Run.cjs",
        "test": "npx quack test",
        "tests": "npx mocha -u tdd --exit -R spec --grep",
        "coverage": "npx quack coverage",
        "postinstall": "cd webinterface && npm install && npm run build && cd ..",
        "build": "npx quack build && cd webinterface && npm install && npm run build && cd ..",
        "docs": "npx quack prepare-docs ./docs -d ./modules",
        "docs-serve": "npx quack docs-serve ./docs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/stevenvelozo/ultravisor.git"
    },
    "author": "steven@velozo.com",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/stevenvelozo/ultravisor/issues"
    },
    "homepage": "https://github.com/stevenvelozo/ultravisor#readme",
    "dependencies": {
        "better-sqlite3": "^11.10.0",
        "cron": "^4.4.0",
        "orator": "^6.0.4",
        "orator-authentication": "^1.0.0",
        "orator-serviceserver-restify": "^2.0.10",
        "pict": "^1.0.363",
        "pict-service-commandlineutility": "^1.0.19",
        "pict-serviceproviderbase": "^1.0.4",
        "ultravisor-beacon": "^0.0.11",
        "ws": "^8.20.0"
    },
    "devDependencies": {
        "pict-docuserve": "^0.1.5",
        "puppeteer": "^24.40.0",
        "quackage": "^1.1.0"
    },
    "mocha": {
        "diff": true,
        "extension": [
            "js"
        ],
        "package": "./package.json",
        "reporter": "spec",
        "slow": "75",
        "timeout": "5000",
        "ui": "tdd",
        "watch-files": [
            "source/**/*.js",
            "source/**/*.cjs",
            "test/**/*.js"
        ],
        "watch-ignore": [
            "lib/vendor"
        ]
    }
}
